<view class="app-container">
  <!-- Sidebar -->
  <view class="sidebar {{isSidebarOpen ? 'open' : ''}}">
    <view class="sidebar-header">
      <text class="title">💬 聊天记录</text>
      <view class="close-btn" bindtap="toggleSidebar">×</view>
    </view>

    <!-- New Chat Button ใน Sidebar -->
    <view class="new-chat-sidebar" bindtap="startNewChat">
      <text class="new-chat-icon">+</text>
      <text class="new-chat-text">创建新聊天</text>
    </view>

    <scroll-view class="history-list" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <block wx:for="{{chatHistory}}" wx:key="session_id">
        <ai-history title="{{item.title}}" active="{{currentChatId === item.session_id}}" chatid="{{item.session_id}}" bind:select="switchChat" bind:delete="deleteChat" />
        
      </block>

      <view wx:if="{{chatHistory.length === 0}}" class="empty-history">
        <text>📝 暂无聊天记录\n请开始新的对话！</text>
      </view>
    </scroll-view>
  </view>

  <!-- Main Content -->
  <view class="main-content">
    <!-- Header (ไม่มีปุ่ม New Chat แล้ว) -->
    <view class="header">
      <view class="menu-icon" bindtap="toggleSidebar">☰</view>
      <text class="brand">LandLink Counsel</text>
      <view class="header-spacer"></view> <!-- เว้นที่ให้สมมาตร -->
    </view>

    <!-- Chat Window -->
    <scroll-view class="chat-window" scroll-y scroll-into-view="{{lastId}}" scroll-with-animation enable-back-to-top>
      <view wx:for="{{messages}}" wx:key="index" id="msg-{{index}}" class="msg-row {{item.role === 'user' ? 'row-user' : 'row-ai'}}">
        <view class="bubble">
          <block wx:if="{{!item.isLoading}}">
            <text user-select>{{item.content}}</text>


            <view class="assets-container" wx:if="{{item.assets.length > 0}}">
              <view class="asset-group-item" wx:for="{{item.assets}}" wx:for-item="asset" wx:key="id">

                <view class="asset-pitch-box" wx:if="{{asset.pitch}}">
                  <text>💡 {{asset.pitch}}</text>
                </view>

                <view class="asset-card">
                  <!-- <image class="asset-image" src="/images/property-placeholder.jpg" mode="aspectFill"></image> -->
                  <view class="asset-info">
                    <view class="asset-name">{{asset.name}}</view>
                    <view class="asset-location">📍 {{asset.province}}</view>
                    <view class="asset-price">฿ {{asset.price}}</view>
                    <button class="detail-btn" bindtap="goToDetail" data-id="{{asset.id}}">查看详情</button>
                  </view>
                </view>

              </view>
            </view>


            <view class="options-container" wx:if="{{item.options && item.options.length > 0}}">
              <view class="opt-btn" wx:for="{{item.options}}" wx:for-item="opt" wx:key="*this" bindtap="handleOptionClick" data-val="{{opt}}" data-msg-idx="{{index}}">
                {{opt}}
              </view>
            </view>

          </block>

          <view wx:else class="dot-typing">
            <view class="dot"></view>
            <view class="dot"></view>
            <view class="dot"></view>
          </view>
        </view>
      </view>

      <!-- <view wx:if="{{messages.length === 0}}" class="empty-chat">
        <text class="welcome-subtitle">您好，我是 LANDLINK COUNSEL

          为您提供泰国相关业务咨询与服务，包括：

          🏢 投资与政府机构
          BOI、IEAT、EEC、DBD、DIW、地方政府、土地局、工业部

          📄 法规与许可
          EIA、FBL、FBC、PDPA、FDA、TISI、DIP、DFT

          💼 税务与金融
          税务局、海关、泰国央行（BOT）

          👷 劳工与签证
          移民局、就业厅、社保（SSO）、劳工保护

          ⚡ 基础设施
          电力（PEA / MEA）、地下水资源

          🏭 工业地产服务
          土地 / 厂房 / 仓库 查询

          👉 或点击下方按钮，开始查找土地 / 厂房 / 仓库</text>
      </view> -->

      <view id="bottom-anchor"></view>
    </scroll-view>


    <view class="quick-actions-bar" wx:if="{{messages.length < 10}}">
      <scroll-view scroll-x="true" class="actions-scroll">
        <view class="action-item" bindtap="startLandSearch">
          <text class="icon">🔍</text> 查找土地 / 仓库
        </view>
        <!-- <view class="action-item" bindtap="sendQuickInquiry" data-msg="ฝากขาย">
          <text class="icon">💡</text> ส่งข้อมูลเพื่อฝากขาย
        </view>
        <view class="action-item" bindtap="sendQuickInquiry" data-msg="ติดต่อเจ้าหน้าที่">
          <text class="icon">📞</text> ติดต่อเจ้าหน้าที่
        </view> -->

      </scroll-view>
    </view>


    <!-- Input Container -->


    <view class="input-container">
      <input class="chat-input" placeholder="请输入您的问题..." value="{{inputVal}}" bindinput="onInput" bindconfirm="handleSend" confirm-type="send" adjust-position="{{true}}" />
      <view class="send-icon {{inputVal ? 'active' : ''}}" bindtap="handleSend">
        <van-icon name="guide-o" />
      </view>
    </view>
  </view>

  <!-- Overlay -->
  <view class="overlay" wx:if="{{isSidebarOpen}}" bindtap="toggleSidebar"></view>
</view>
<tabBar current="0" />