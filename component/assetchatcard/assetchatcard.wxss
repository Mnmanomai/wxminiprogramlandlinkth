/* component/assetchatcard/assetchatcard.wxss */
.limitline{
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.listline{
  display: flex;
  gap: 2px;
  align-items: center;
}
.textprice{
  font-weight: 600;
  text-align: end;
  /* display: flex;
  justify-content: center; */
}

.text-sale{
  color: green;
}
.text-rent{
  color: orange;
}

.tag{
  font-size: 10px;
  border: solid 1px ;
  border-radius: 4px;
  padding : 0px 2px;
}