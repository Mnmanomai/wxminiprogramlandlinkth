/* component/cardinpost/cardinpost.wxss */

.description{
  padding: 10px;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.nameasset{
  font-weight: 700;
  font-size: 15px;
}

.carousel-container {
  width: 100%;
  height: 300px;
  position: relative;
  overflow: hidden;
}

.carousel {
  width: 100%;
  height: 100%;
}

.carousel-image {
  width: 100%;
  height: 100%;
  display: block;
}

.descriptiondeatil {
  display: flex;
  gap: 2px;
  color: rgb(48, 48, 48);
  font-size: 14px;
}

.tagnprice {
  display: flex;
  justify-content: space-between;
}

.tagdetail {
  border: 1px;
  border-radius: 4px;
  border-style: solid;
  width: auto;
  padding-left: 8px;
  padding-right: 8px;
  font-size: 12px;
}

.tagmain {
  display: flex;
  gap: 3px;
}

