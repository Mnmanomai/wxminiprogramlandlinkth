.history-item {
  margin: 12rpx 20rpx;
  padding: 24rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.2); 
  border: 1rpx solid rgba(255, 255, 255, 0.3); 
  transition: all 0.3s ease;
  box-sizing: border-box;
}

.item-content {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.icon-chat {
  margin-right: 20rpx;
  font-size: 28rpx;
  opacity: 0.7;
}

.chat-name {
  font-size: 28rpx;
  color: #1e293b; 
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 380rpx;
}

.history-item.active {
  background: rgba(255, 255, 255, 0.6); 
  border-color: rgba(149, 185, 245, 0.5);
  box-shadow: 0 8rpx 32rpx rgba(59, 130, 246, 0.1); 
  transform: scale(1.02);
}

.history-item.active .chat-name {
  color: #3b82f6; 
  font-weight: 600;
}


.delete-wrapper {
  padding: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.6;
}

.delete-wrapper:active {
  opacity: 1;
  transform: scale(1.2);
}