<!--component/chatlist/index.wxml-->
<view class="mainlist">
  <view class="list" bind:tap="Nexttofeed" data-idfeed="{{chatno}}" data-namechat="{{namechat}}">
    <!-- image -->
    <view class="imagespart">
      <view class="" style="position: relative;width: 60px; height: 60px; color: rgb(0, 0, 0); background: linear-gradient(to bottom right, transparent calc(50% - 1px), rgb(0, 25, 0), transparent calc(50% + 1px));">
        <view class="" style="position: absolute;top: 2px;left: 4px;font-weight: 700;font-size: 15px;">{{month}}</view>
        <view class="" style="position: absolute;bottom: 2px;right: 4px;font-size: 15px;">{{date}}</view>
      </view>
    </view>

    <!-- content -->
    <view class="namepart">
      <view class="limit1" style="font-size: 14px;font-weight: 400;text-transform: capitalize;">
        {{namechat}}
      </view>
      <view class="limit1" style="color: rgb(0,0,0,0.7);display: flex;">
        <view class="textnewmsg">{{textnew}} </view>
        <view class="text-description" wx:if="{{timenew}}"> • {{timenew}}</view>
      </view>
    </view>

    <!-- new notification -->
    <view class="notipart">
      <view class="notitag" wx:if="{{unreadno > 0}}">
        {{unreadno}}
      </view>

    </view>

    <!-- <view class="optionpart">
      <van-icon name="setting-o" size="26"/>
    </view> -->
    <!-- <view class="deletepart">
      <van-icon name="delete-o" size="26"/>
    </view> -->
  </view>
</view>